# PagLoop (https://api.pagloop.tech)
PAGLOOP_CLIENT_ID=seu_client_id
PAGLOOP_CLIENT_SECRET=seu_client_secret

# URL base do backend para o gateway enviar callbacks (ex: https://seusite.com ou http://localhost:3001)
CALLBACK_BASE_URL=http://localhost:3001

PORT=3001

# Evolution API (envio de mensagem WhatsApp com botões)
EVOLUTION_API_URL=https://evolutionpro-evolution-api.seu-host.com
EVOLUTION_INSTANCE_ID=sua_instance_id
EVOLUTION_API_KEY=sua_api_key
